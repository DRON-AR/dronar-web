# ============================================================
# DRONAR — Variables de entorno de referencia (raíz del monorepo)
# Copiar a .env.local (frontend) / .env (backend) según corresponda.
# NUNCA commitear un archivo .env real. Todas las claves reales
# viven en los secretos de CI/CD y en el panel de Vercel/Render.
# ============================================================

# --- Frontend / origen permitido en CORS ---
FRONTEND_ORIGIN=https://app.camperaeronautical.com

# --- Anthropic Claude (solo backend, nunca en cliente) ---
CLAUDE_API_KEY=

# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE=
DATABASE_URL=

# --- Auth ---
JWT_SECRET=

# --- Storage (si se usa S3 en vez de Supabase Storage) ---
S3_BUCKET=

# --- Email (motor de alertas, bloque 7) ---
SMTP_URL=

# --- Observabilidad ---
SENTRY_DSN=

# Variables de entorno del BACKEND — nunca se exponen al cliente.

NODE_ENV=development
PORT=4000

FRONTEND_ORIGIN=http://localhost:3000

# Anthropic Claude — solo se usa desde el proxy backend (Bloque 4)
CLAUDE_API_KEY=
# String de modelo tal como aparece en tu consola de Anthropic
# (p. ej. claude-sonnet-5, claude-opus-4-8 — verifica cuál tiene tu cuenta,
# no se asume un default aquí porque cambia con el tiempo).
CLAUDE_MODEL=

# Rate limit específico de /api/claude (más estricto que el global de arriba,
# porque cada llamada aquí cuesta dinero real en la cuenta de Anthropic).
CLAUDE_RATE_LIMIT_MAX=10
CLAUDE_RATE_LIMIT_WINDOW=1 minute

# Supabase (service role solo aquí, jamás en frontend)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE=
DATABASE_URL=

JWT_SECRET=

RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=1 minute

SENTRY_DSN=

# Generador de certificados (Bloque 6) — ruta al binario de Chromium.
# En local: instala chromium y apunta aquí (p. ej. /usr/bin/chromium-browser
# en Debian/Ubuntu, o el que reporte `which chromium`). En producción la
# fija backend/Dockerfile — no se descarga vía npm install.
PUPPETEER_EXECUTABLE_PATH=

# Motor de alertas (Bloque 7)
SMTP_FROM=alertas@camperaeronautical.com
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_SECRET=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@camperaeronautical.com
# Secreto compartido para POST /api/alerts/scan — lo usa el scheduler
# (cron), no un usuario. Genera algo largo y aleatorio, no un valor obvio.
ALERTS_SCAN_SECRET=
MEDICAL_EXPIRING_DAYS_THRESHOLD=30
PRE_FLIGHT_PENDING_HOURS_THRESHOLD=24
